generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    Int                    @id @default(autoincrement())
  email                 String                 @unique
  password              String
  name                  String
  initials              String?
  role                  Role                   @default(STUDENT)
  status                String                 @default("Active")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  enrolledYearGroupId   Int?
  address               String?
  avatarUrl             String?
  dateOfBirth           DateTime?
  enrollmentDate        DateTime               @default(now())
  gender                Gender?
  phoneNumber           String?
  specialization        String?
  announcements         Announcement[]         @relation("Author")
  attendance            Attendance[]
  feePayments           FeePayment[]
  grades                Grade[]                @relation("StudentGrades")
  givenGrades           Grade[]                @relation("TeacherGrades")
  reportSummaries       StudentReportSummary[] @relation("StudentReportSummaries")
  issuedReportSummaries StudentReportSummary[] @relation("TeacherReportSummaries")
  materials             Material[]             @relation("TeacherMaterials")
  refreshTokens         RefreshToken[]
  taughtTimetableSlots  Timetable[]            @relation("TeacherTimetableSlots")
  enrolledYearGroup     YearGroup?             @relation("StudentYearGroup", fields: [enrolledYearGroupId], references: [id])
  taughtYearGroups      YearGroup[]            @relation("TeacherYearGroups")
}

model Subject {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  grades      Grade[]
  materials   Material[]
  timetable   Timetable[]
  yearGroups  YearGroup[] @relation("SubjectYearGroups")
}

model YearGroup {
  id              Int                    @id @default(autoincrement())
  name            String
  level           Level                  @default(Primary)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  roomNumber      String?
  capacity        Int?
  announcements   Announcement[]         @relation("TargetYearGroup")
  fees            Fee[]
  materials       Material[]
  timetables      Timetable[]
  reportSummaries StudentReportSummary[]
  students        User[]                 @relation("StudentYearGroup")
  subjects        Subject[]              @relation("SubjectYearGroups")
  teachers        User[]                 @relation("TeacherYearGroups")
}

model StudentReportSummary {
  id             Int        @id @default(autoincrement())
  studentId      Int
  teacherId      Int
  yearGroupId    Int?
  term           String?
  academicYear   String?
  overallGrade   String?
  performance    String?
  teacherComment String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  student        User       @relation("StudentReportSummaries", fields: [studentId], references: [id], onDelete: Cascade)
  teacher        User       @relation("TeacherReportSummaries", fields: [teacherId], references: [id], onDelete: Restrict)
  yearGroup      YearGroup? @relation(fields: [yearGroupId], references: [id], onDelete: SetNull)

  @@unique([studentId])
}

model Grade {
  id            Int      @id @default(autoincrement())
  score         Float?
  grade         String?
  studentId     Int
  subjectId     Int
  teacherId     Int
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  assignmentAvg Float?
  midterm       Float?
  projectFinal  Float?
  performance   String?
  teacherReport String?
  test          Boolean
  test2         Boolean
  student       User     @relation("StudentGrades", fields: [studentId], references: [id])
  subject       Subject  @relation(fields: [subjectId], references: [id])
  teacher       User     @relation("TeacherGrades", fields: [teacherId], references: [id])
}

model Attendance {
  id        Int              @id @default(autoincrement())
  status    AttendanceStatus @default(P)
  date      DateTime         @default(now())
  studentId Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  student   User             @relation(fields: [studentId], references: [id])
}

model Announcement {
  id                Int        @id @default(autoincrement())
  title             String
  content           String
  priority          Priority   @default(Normal)
  authorId          Int
  targetType        TargetType @default(ALL)
  targetYearGroupId Int?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  author            User       @relation("Author", fields: [authorId], references: [id])
  targetYearGroup   YearGroup? @relation("TargetYearGroup", fields: [targetYearGroupId], references: [id])
}

model Period {
  id         Int         @id @default(autoincrement())
  label      String
  startTime  String
  endTime    String
  isBreak    Boolean     @default(false)
  timetables Timetable[]
}

model Timetable {
  id          Int       @id @default(autoincrement())
  day         DayOfWeek
  yearGroupId Int
  periodId    Int
  subjectId   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  teacherId   Int?
  period      Period    @relation(fields: [periodId], references: [id])
  subject     Subject?  @relation(fields: [subjectId], references: [id])
  teacher     User?     @relation("TeacherTimetableSlots", fields: [teacherId], references: [id])
  yearGroup   YearGroup @relation(fields: [yearGroupId], references: [id])

  @@unique([yearGroupId, day, periodId])
}

model Fee {
  id          Int          @id @default(autoincrement())
  amount      Float
  yearGroupId Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  title       String
  description String?
  yearGroup   YearGroup    @relation(fields: [yearGroupId], references: [id])
  payments    FeePayment[]
}

model FeePayment {
  id            Int       @id @default(autoincrement())
  feeId         Int
  studentId     Int
  amountPaid    Float     @default(0)
  amountInWords String?
  isFullyPaid   Boolean   @default(false)
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  fee           Fee       @relation(fields: [feeId], references: [id], onDelete: Cascade)
  student       User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([feeId, studentId])
}

model RefreshToken {
  id          String   @id @default(uuid())
  hashedToken String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Material {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String
  fileType    String?
  isPublished Boolean    @default(true)
  subjectId   Int
  teacherId   Int
  yearGroupId Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  subject     Subject    @relation(fields: [subjectId], references: [id])
  teacher     User       @relation("TeacherMaterials", fields: [teacherId], references: [id])
  yearGroup   YearGroup? @relation(fields: [yearGroupId], references: [id])
}

model SchoolSetting {
  id          Int      @id @default(1)
  name        String
  description String
  term        String
  year        String
  language    String   @default("en")
  logo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Gender {
  Male
  Female
  Other
}

enum Level {
  Primary
  JuniorSecondary
  SeniorSecondary
  University
}

enum AttendanceStatus {
  P
  A
  T
  H
}

enum Priority {
  Normal
  Important
  Urgent
}

enum TargetType {
  ALL
  YEAR_GROUP
  TEACHERS_ONLY
}

enum DayOfWeek {
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
  Sunday
}

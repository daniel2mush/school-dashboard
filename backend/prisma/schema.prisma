// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  password       String
  name           String
  initials       String?
  gender         Gender?
  dateOfBirth    DateTime?
  phoneNumber    String?
  address        String?
  avatarUrl      String?
  specialization String? // For teachers
  enrollmentDate DateTime  @default(now()) // For students
  role           Role      @default(STUDENT)
  status         String    @default("Active")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relationships
  // For students:
  enrolledYearGroup   YearGroup?   @relation("StudentYearGroup", fields: [enrolledYearGroupId], references: [id])
  enrolledYearGroupId Int?
  grades              Grade[]      @relation("StudentGrades")
  attendance          Attendance[]

  // For teachers:
  taughtYearGroups YearGroup[] @relation("TeacherYearGroups")
  givenGrades      Grade[]     @relation("TeacherGrades")

  // Announcements
  announcements Announcement[] @relation("Author")
  refreshTokens RefreshToken[]
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Gender {
  Male
  Female
  Other
}

model Subject {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  yearGroups  YearGroup[] @relation("SubjectYearGroups")
  grades      Grade[]
  timetable   Timetable[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model YearGroup {
  id         Int     @id @default(autoincrement())
  name       String
  level      Level   @default(Primary)
  roomNumber String?

  // Relationships
  students      User[]         @relation("StudentYearGroup")
  teachers      User[]         @relation("TeacherYearGroups")
  subjects      Subject[]      @relation("SubjectYearGroups")
  fees          Fee[]
  timetables    Timetable[]
  announcements Announcement[] @relation("TargetYearGroup")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Level {
  Primary
  JuniorSecondary
  SeniorSecondary
  University
}

model Grade {
  id        Int      @id @default(autoincrement())
  score     Float
  grade     String // e.g., "A", "B+"
  student   User     @relation("StudentGrades", fields: [studentId], references: [id])
  studentId Int
  subject   Subject  @relation(fields: [subjectId], references: [id])
  subjectId Int
  teacher   User     @relation("TeacherGrades", fields: [teacherId], references: [id])
  teacherId Int
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id        Int              @id @default(autoincrement())
  status    AttendanceStatus @default(P)
  date      DateTime         @default(now())
  student   User             @relation(fields: [studentId], references: [id])
  studentId Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

enum AttendanceStatus {
  P // Present
  A // Absent
  T // Late
  H // Holiday
}

model Announcement {
  id                Int        @id @default(autoincrement())
  title             String
  content           String
  priority          Priority   @default(Normal)
  author            User       @relation("Author", fields: [authorId], references: [id])
  authorId          Int
  targetType        TargetType @default(ALL)
  targetYearGroup   YearGroup? @relation("TargetYearGroup", fields: [targetYearGroupId], references: [id])
  targetYearGroupId Int?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

enum Priority {
  Normal
  Important
  Urgent
}

enum TargetType {
  ALL
  YEAR_GROUP
  TEACHERS_ONLY
}

model Period {
  id         Int         @id @default(autoincrement())
  label      String // e.g., "Period 1"
  startTime  String // e.g., "7:30"
  endTime    String // e.g., "8:30"
  isBreak    Boolean     @default(false)
  timetables Timetable[]
}

model Timetable {
  id          Int       @id @default(autoincrement())
  day         DayOfWeek
  yearGroup   YearGroup @relation(fields: [yearGroupId], references: [id])
  yearGroupId Int
  period      Period    @relation(fields: [periodId], references: [id])
  periodId    Int
  subject     Subject?  @relation(fields: [subjectId], references: [id])
  subjectId   Int? // Null for free periods

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([yearGroupId, day, periodId])
}

enum DayOfWeek {
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
  Sunday
}

model Fee {
  id          Int       @id @default(autoincrement())
  amount      Float
  paid        Float     @default(0)
  yearGroup   YearGroup @relation(fields: [yearGroupId], references: [id])
  yearGroupId Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

//refreshToken
model RefreshToken {
  id          String   @id @default(uuid())
  hashedToken String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
